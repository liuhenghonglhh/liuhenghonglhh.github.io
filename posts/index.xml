 &lt;td&gt;&lt;code&gt;type: &amp;quot;data&amp;quot;&lt;/code&gt;, &lt;code&gt;layout: &amp;quot;data&amp;quot;&lt;/code&gt;&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
